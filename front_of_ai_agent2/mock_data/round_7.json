  "ai_logs": [
    {
      "name": "Bob",
      "emoji": "💰",
      "thought": "这疯子身上居然带着这么多钱。我作为老兵对钱没有太大的欲望，但拿回去给 Alice 交差能换取更好的待遇。那个情报贩子Cooper在暗中偷看，我得用眼神警告他最好闭嘴。",
      "decision": "拾取遗产并警告 Cooper"
    },
    {
      "name": "Cooper",
      "emoji": "🦅",
      "thought": "命案的把柄确确实实落在我手里了，这比直接捡死人的钱更有长远价值。我得去古老城镇的废墟里找找有没有能克制老兵武力的魔法遗物，为以后的谈判增加筹码。",
      "decision": "前往 🏛️古老城镇"
    },
    {
      "name": "Flash",
      "emoji": "🍄",
      "thought": "肚子饿得像火烧一样难受。河边根本找不到任何吃的，我得硬着头皮去废弃矿洞看看有没有长出可食用的蘑菇，哪怕是前人留下的残羹冷炙也行，再饿下去我就要死了。",
      "decision": "前往 ⛏️废弃矿洞"
    },
    {
      "name": "Alice",
      "emoji": "👑",
      "thought": "David 终于同意为我工作了，他那点可怜的薪水要求对我来说不值一提。只要 Bob 带着森林里的物资回来，我的小团体就能在这个混乱的酒馆里建立起绝对的统治阶级。",
      "decision": "留在 🏨中央酒馆"
    },
    {
      "name": "David",
      "emoji": "🍞",
      "thought": "拿了 Alice 预支的食物，我感觉身体恢复了许多。不用再提心吊胆地算计别人，这种感觉真好。现在我只想安安稳稳地替她打工等雪停，然后立刻回家看我的女儿。",
      "decision": "接受 Alice 的招募"
    }
  ],
  "story_log": [
    {
      "round": 7,
      "text": "第 7 轮 - 财富转移。Bob 拾取了 Eggo 的遗产，而 Cooper 犹如秃鹫般在暗中记录着一切。Flash 因为极度饥饿，被迫向危险的矿洞移动。"
    }
  ]
